# Traytor - Spec Driven Development CLI
# Copy this file to .env and fill in your values.

# ─── Provider ────────────────────────────────────────────────────────────────
# LLM provider: anthropic | openai | openai-compatible
TRAYTOR_PROVIDER=anthropic

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
TRAYTOR_ANTHROPIC_MODEL=claude-sonnet-4-20250514
TRAYTOR_ANTHROPIC_MAX_TOKENS=4096
TRAYTOR_ANTHROPIC_TEMPERATURE=0
TRAYTOR_ANTHROPIC_BASE_URL=

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
TRAYTOR_OPENAI_MODEL=gpt-4o
TRAYTOR_OPENAI_MAX_TOKENS=4096
TRAYTOR_OPENAI_TEMPERATURE=0
OPENAI_BASE_URL=

# ─── OpenAI-Compatible ───────────────────────────────────────────────────────
TRAYTOR_COMPATIBLE_API_KEY=
TRAYTOR_COMPATIBLE_MODEL=
TRAYTOR_COMPATIBLE_BASE_URL=

# ─── General ─────────────────────────────────────────────────────────────────
TRAYTOR_DEFAULT_AGENT=claude
TRAYTOR_LOG_LEVEL=info
TRAYTOR_DATA_DIR=~/.traytor/data

# ─── GitHub (for ticket-assist) ─────────────────────────────────────────────
GITHUB_TOKEN=
