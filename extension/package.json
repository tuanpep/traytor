{
  "name": "traytor-vscode",
  "displayName": "Traytor - Spec Driven Development",
  "description": "IDE integration for the Traytor spec-driven development CLI tool",
  "version": "0.1.0",
  "publisher": "traytor",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Developer Tools"
  ],
  "activationEvents": [
    "onCommand:traytor.createPlan",
    "onCommand:traytor.executeTask",
    "onCommand:traytor.verifyTask",
    "onCommand:traytor.showHistory",
    "onCommand:traytor.refreshTasks"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "traytor.createPlan",
        "title": "Traytor: Create Plan",
        "category": "Traytor"
      },
      {
        "command": "traytor.executeTask",
        "title": "Traytor: Execute Task",
        "category": "Traytor"
      },
      {
        "command": "traytor.verifyTask",
        "title": "Traytor: Verify Task",
        "category": "Traytor"
      },
      {
        "command": "traytor.showHistory",
        "title": "Traytor: Show Task History",
        "category": "Traytor"
      },
      {
        "command": "traytor.refreshTasks",
        "title": "Traytor: Refresh Task List",
        "category": "Traytor",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "traytor-sidebar",
          "title": "Traytor Tasks",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "traytor-sidebar": [
        {
          "id": "traytorTasksView",
          "name": "Task List",
          "icon": "$(checklist)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "traytorTasksView",
        "contents": "No tasks found.\n[Traytor: Create Plan](command:traytor.createPlan)"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
