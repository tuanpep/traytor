{
  "name": "traytor",
  "version": "1.0.0",
  "description": "Traytor - Personal spec-driven development CLI tool",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "traytor": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/bin/traytor.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,cjs}\"",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.1",
    "diff": "^8.0.4",
    "dotenv": "^16.6.1",
    "glob": "^13.0.6",
    "handlebars": "^4.7.9",
    "ignore": "^7.0.5",
    "inquirer": "^13.3.2",
    "openai": "^6.33.0",
    "ora": "^9.3.0",
    "simple-git": "^3.33.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.33.0"
}
